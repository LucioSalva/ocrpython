# =========================================================
# OCR app - environment variables (copy this file to .env)
# =========================================================
# IMPORTANT: change credentials below before first run.

# --- PostgreSQL ---
POSTGRES_USER=ocr
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=ocr

# --- Host ports (only bound to 127.0.0.1, see compose) ---
BACKEND_PORT=8000
FRONTEND_PORT=8080
DB_PORT=5432

# --- App config ---
OCR_ENGINE=tesseract
MAX_UPLOAD_MB=20
STORAGE_PATH=/storage

# --- CORS (browser -> FastAPI, since PHP is NOT a proxy) ---
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:8080
